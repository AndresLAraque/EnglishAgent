# Notion
NOTION_TOKEN=ntn_your_integration_token_here
NOTION_WORDS_DB=your_words_database_id_here
NOTION_READINGS_DB=your_readings_database_id_here
NOTION_ACTIVITY_DB=your_activity_database_id_here
NOTION_TOPICS_DB=your_writing_topics_database_id_here
NOTION_SUBMISSIONS_DB=your_writing_submissions_database_id_here
NOTION_MISTAKES_DB=your_mistakes_bank_database_id_here
NOTION_READING_GAMES_DB=your_reading_games_database_id_here

# Telegram (for notify command)
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_telegram_user_id

# LLM Provider selection (deepseek or ollama)
# LLM_PROVIDER=deepseek

# DeepSeek (cloud AI, needs API key)
DEEPSEEK_API_KEY=sk-your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Ollama (local AI, needs Ollama running)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:0.5b
# Optional: use a different (e.g. bigger) model just for grading writing submissions
OLLAMA_WRITING_MODEL=qwen2.5:0.5b
